ANTHROPIC_API_KEY=
COSMOS_CONNECTION_STRING=
COSMOS_DB_NAME=
ADMIN_PIN=
NEXT_PUBLIC_MAX_PLAYERS=

# Required in production (NODE_ENV=production): the HMAC key for admin/member
# session cookies. Missing/short -> the app refuses to sign sessions (fail-closed,
# #142). Generate with: openssl rand -hex 32. Local dev/test fall back to a
# sentinel if unset.
SESSION_SECRET=

# Optional. Pin a single trusted client-IP header (e.g. cf-connecting-ip behind
# Cloudflare) for rate limiting on a non-Azure host; skips the spoofable
# X-Forwarded-For fallback. Leave unset on Azure App Service (default behaviour).
TRUSTED_IP_HEADER=

# Required: must match next.config.js basePath. Without it the client fetches
# /api/* unprefixed -> 404 -> a false app-wide "You're offline" state.
NEXT_PUBLIC_BASE_PATH=/bpm
