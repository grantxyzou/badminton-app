    },
    "input-focus-border": {
      "$value": "#4ade8073",
      "$extensions": { "com.figma": { "mode": { "Dark": "#4ade8073", "Light": "#16a34a80" } } }
    },
    "nav-active": {
      "$value": "#4ade80",
      "$extensions": { "com.figma": { "mode": { "Dark": "#4ade80", "Light": "#16a34a" } } }
    },
    "nav-inactive": {
      "$value": "#ffffff80",
      "$extensions": { "com.figma": { "mode": { "Dark": "#ffffff80", "Light": "#00000066" } } }
    },
