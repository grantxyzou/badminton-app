# dependencies
node_modules/

# superpowers brainstorm artifacts
.superpowers/

# next.js
.next/
out/

# environment variables (keep secrets out of git)
.env.local
.env*.local

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript
tsconfig.tsbuildinfo

# misc
.DS_Store
*.pem

# deployment artifacts
*.zip
.azure/

# Worktrees
.worktrees/

# Session-generated review/screenshot artifacts
c1-review-*.png
c1-polish-*.png
review-mobile-*.png
branch-admin.png
branch-non-admin.png
live-admin.png
live-non-admin.png
favicon.png

# Design playgrounds (one-off explorations, not shipped)
*-playground.html

# Playwright MCP screenshot cache
.playwright-mcp/

# Agent memory (per-machine scratch — agents regenerate on next run)
.claude/agent-memory/

# Claude Code runtime lock files
.claude/scheduled_tasks.lock
.claude/*.lock

# Plugin-settings pattern: per-project state files (user-managed, not shared)
# Each .claude/<name>.local.md stores YAML frontmatter config for a hook or
# plugin. Templates live in docs/automation/ — copy and customize per machine.
.claude/*.local.md
.claude/*.local.json

# Auto-generated by scripts/extract-unreleased.mjs (regenerates on every build/dev)
public/changelog-unreleased.json

# Screenshot/debugging artifacts (numbered prefix or dated)
/[0-9][0-9]-*.png
/[0-9][0-9][a-z]-*.png
